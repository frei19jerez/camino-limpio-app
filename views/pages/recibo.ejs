<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

  <div class="row justify-content-center">

    <div class="col-md-6">

      <div class="card shadow border-0">

        <div class="card-body text-center p-4">

          <h2 class="mb-1">🚗 Camino Limpio</h2>

          <p class="text-muted mb-4">
            Servicio Profesional de Lavado
          </p>

          <hr>

          <div class="text-start">

            <p>
              <strong>👤 Cliente:</strong><br>
              <%= lavado.cliente ? lavado.cliente.nombre : 'Cliente' %>
            </p>

            <p>
              <strong>📞 Teléfono:</strong><br>
              <%= lavado.cliente ? lavado.cliente.telefono : '-' %>
            </p>

            <p>
              <strong>👷 Empleado:</strong><br>
              <%= lavado.empleado ? lavado.empleado.nombre : '-' %>
            </p>

            <hr>

            <p>
              <strong>🔢 Placa:</strong><br>
              <%= lavado.placa %>
            </p>

            <p>
              <strong>🚙 Vehículo:</strong><br>
              <%= lavado.vehiculo.charAt(0).toUpperCase() + lavado.vehiculo.slice(1) %>
            </p>

            <p>
              <strong>💰 Precio:</strong><br>
              $<%= Number(lavado.precio).toLocaleString('es-CO') %>
            </p>

            <p>
              <strong>📅 Fecha:</strong><br>
              <%= lavado.fecha %>
            </p>

          </div>

          <hr class="my-4">

          <div class="d-grid gap-2">

            <button onclick="window.print()" class="btn btn-primary">
              🖨 Imprimir Recibo
            </button>

            <button onclick="enviarWhatsApp()" class="btn btn-success">
              📱 Enviar por WhatsApp
            </button>

            <a href="../" class="btn btn-secondary">
              ⬅ Volver
            </a>

          </div>

        </div>

      </div>

    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>

function enviarWhatsApp(){

  const mensaje = `🧾 *CAMINO LIMPIO*

🚗 Servicio de Lavado

👤 Cliente: *<%= lavado.cliente ? lavado.cliente.nombre : 'Cliente' %>*
📞 Teléfono: *<%= lavado.cliente ? lavado.cliente.telefono : '-' %>*

👷 Atendido por: *<%= lavado.empleado ? lavado.empleado.nombre : '-' %>*

🔢 Placa: *<%= lavado.placa %>*
🚙 Vehículo: *<%= lavado.vehiculo %>*

💰 Precio: *$<%= Number(lavado.precio).toLocaleString('es-CO') %>*

📅 Fecha: *<%= lavado.fecha %>*

Gracias por confiar en *Camino Limpio* 🚗
Puerto Araujo - Santander`;

  const url =
  "https://wa.me/?text=" + encodeURIComponent(mensaje);

  window.open(url, "_blank");

}

</script>