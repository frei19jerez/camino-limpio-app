```ejs
<!DOCTYPE html>
<html lang="es">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>Camino Limpio</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

  <div class="container mt-5">

    <div class="row justify-content-center">

      <div class="col-md-6">

        <div class="card shadow">

          <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">

              <h2 class="mb-0">🚗 Camino Limpio</h2>

              <button type="button" onclick="irA('/panel')" class="btn btn-success">
                📊 Ver Panel
              </button>

            </div>

            <form method="POST" id="formLavado">

              <div class="mb-3">
                <label class="form-label">Nombre Cliente</label>
                <input
                  type="text"
                  name="cliente"
                  class="form-control"
                  placeholder="Freimel"
                  required
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Teléfono Cliente</label>
                <input
                  type="text"
                  name="telefono"
                  class="form-control"
                  placeholder="573001234567"
                  required
                >
                <small class="text-muted">
                  Formato: 573001234567
                </small>
              </div>

              <div class="mb-3">
                <label class="form-label">Trabajador</label>
                <input
                  type="text"
                  name="empleado"
                  class="form-control"
                  placeholder="Carlos"
                  required
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Placa</label>
                <input
                  type="text"
                  name="placa"
                  id="placa"
                  class="form-control"
                  placeholder="ABC123"
                  required
                  style="text-transform: uppercase;"
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Vehículo</label>
                <select name="vehiculo" id="vehiculo" class="form-select" required>
                  <option value="">Seleccione</option>
                  <option value="carro">Carro</option>
                  <option value="moto">Moto</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Precio</label>
                <input
                  name="precio"
                  id="precio"
                  type="number"
                  class="form-control"
                  placeholder="20000"
                  required
                  min="0"
                >
                <small class="text-muted" id="precioTexto"></small>
              </div>

              <button type="submit" class="btn btn-primary w-100">
                Generar Recibo
              </button>

            </form>

          </div>

        </div>

      </div>

    </div>

  </div>

  <script>

    function baseRuntime() {
      const partes = window.location.pathname.split('/').filter(Boolean);

      if (partes[0] === 'runtime' && partes[1]) {
        return '/runtime/' + partes[1];
      }

      return '';
    }

    function irA(ruta) {
      window.location.href = baseRuntime() + ruta;
    }

    const formLavado = document.getElementById('formLavado');
    formLavado.action = baseRuntime() + '/lavado/crear';

    const placa = document.getElementById('placa');

    placa.addEventListener('input', function () {
      this.value = this.value.toUpperCase();
    });

    const precios = {
      moto: 20000,
      carro: 50000
    };

    const vehiculo = document.getElementById('vehiculo');
    const precio = document.getElementById('precio');
    const precioTexto = document.getElementById('precioTexto');

    vehiculo.addEventListener('change', function () {
      const tipo = this.value;

      if (precios[tipo]) {
        precio.value = precios[tipo];

        precioTexto.innerText =
          'Precio sugerido: $' +
          precios[tipo].toLocaleString('es-CO');
      } else {
        precio.value = '';
        precioTexto.innerText = '';
      }
    });

  </script>

</body>

</html>
```
